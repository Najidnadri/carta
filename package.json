{
  "name": "carta",
  "version": "0.0.0",
  "description": "GPU-accelerated technical charting library built on PixiJS v8 — event-driven, mobile-first, interval-aligned TimeSeriesChart.",
  "license": "MIT",
  "author": {
    "name": "Najid Nadri",
    "email": "muhd.najid.nadri@gmail.com",
    "url": "https://github.com/najidnadri"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/carta.cjs",
  "module": "./dist/carta.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/carta.js",
      "require": "./dist/carta.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "pnpm test && pnpm test:e2e",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix"
  },
  "keywords": [
    "chart",
    "charting",
    "technical-analysis",
    "pixijs",
    "webgl",
    "finance",
    "candlestick"
  ],
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "pixi.js": "^8.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
